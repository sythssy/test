# ── Supabase（当前业务库 + Auth；与 Neon 二选一完成迁移前需保留）──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 【必填】通行证新用户静默注册：Shadow Auth 使用此密钥调用 auth.admin.createUser
# 在 Supabase：Project Settings → API → service_role（仅服务端使用，切勿暴露到浏览器）
SUPABASE_SERVICE_ROLE_KEY=

# ── Neon（Vercel 官方集成一键注入，变量名以 Vercel 控制台为准）──
# 用于验证：GET /api/health/neon ；完整迁到 Neon 前业务仍走 Supabase
# DATABASE_URL=

# Dify 服务端配置（禁止 NEXT_PUBLIC 前缀）
DIFY_API_BASE_URL=
DIFY_API_KEY=
# 可选：工作流中系统提示词变量名，默认 system_prompt
# DIFY_SYSTEM_PROMPT_INPUT_KEY=system_prompt

# 兑换页「获取激活码」跳转链接（如面包多店铺主页，仅 URL，勿放密钥）
# NEXT_PUBLIC_CDK_SHOP_URL=https://example.com

# 兑换弹窗底部说明（可填微信 / 闲鱼文案，展示在网页上不敏感即可）
# NEXT_PUBLIC_CDK_CONTACT_HINT=获取激活码请联系微信：xxx
